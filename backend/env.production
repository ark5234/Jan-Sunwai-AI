APP_ENV=production
RATE_LIMIT_ENABLED=true
MONGODB_URL=mongodb://mongodb:27017/jan_sunwai_db
MONGO_URL=mongodb://mongodb:27017/jan_sunwai_db
DB_NAME=jan_sunwai_db

JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

ALLOWED_ORIGINS=https://example.ndmc.gov.in

OLLAMA_BASE_URL=http://host.docker.internal:11434
VISION_MODEL=qwen2.5vl:3b
MID_VISION_MODEL=granite3.2-vision:2b
FALLBACK_VISION_MODEL=granite3.2-vision:2b
REASONING_MODEL=llama3.2:1b
VISION_TIMEOUT_SECONDS=240
LLM_INLINE_TIMEOUT_SECONDS=15
LLM_QUEUE_WORKERS=2
RULE_ENGINE_ONLY=false
AMBIGUITY_THRESHOLD=2.0
UNLOAD_AFTER_REASONING=true

COMPLAINT_OUTPUT_MODE=email
MODEL_UNLOAD_TIMEOUT_SECONDS=30
MODEL_UNLOAD_POLL_INTERVAL_SECONDS=0.1
KEEP_REASONING_MODEL_WARM=false

DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@jan-sunwai.gov.in
