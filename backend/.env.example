# Jan-Sunwai AI unified environment file
# Edit values here for both local and production usage.

MONGODB_URL=mongodb://localhost:27017
DB_NAME=jan_sunwai_db
NDMC_MONGODB_URL=mongodb://localhost:27019
NDMC_DB_NAME=ndmc_analysis_db
NDMC_ANALYSIS_COLLECTION=ndmc_analysis

APP_ENV=development

# P1-F: Rate limiting MUST be true in production
RATE_LIMIT_ENABLED=false

# Generate a fresh key: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace_with_your_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL=llava-phi3
MID_VISION_MODEL=llava-phi3
FALLBACK_VISION_MODEL=llava-phi3
REASONING_MODEL=llama3.2:1b
ENABLE_OLLAMA_TRANSLATION_FALLBACK=true
VISION_TIMEOUT_SECONDS=240
LLM_INLINE_TIMEOUT_SECONDS=8
LLM_QUEUE_WORKERS=2
RULE_ENGINE_ONLY=false
AMBIGUITY_THRESHOLD=2.0
UNLOAD_AFTER_REASONING=true
COMPLAINT_OUTPUT_MODE=email
MODEL_UNLOAD_TIMEOUT_SECONDS=30
MODEL_UNLOAD_POLL_INTERVAL_SECONDS=0.1
KEEP_REASONING_MODEL_WARM=false

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# P1-G: SMTP credentials
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@jan-sunwai.local
SMTP_USERNAME=
SMTP_PASSWORD=

DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

NDMC_API_ENABLED=true
NDMC_API_URL=https://api.example.com/ndmc/predict
NDMC_API_TOKEN=replace_with_ndmc_auth_token
NDMC_API_TIMEOUT_SECONDS=30